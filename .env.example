# Copier vers .env.local et renseigner les vraies valeurs.
# URL du site (obligatoire pour Stripe Checkout / merci)
NEXT_PUBLIC_URL=http://localhost:3000

# Stripe — Dashboard : https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxx
# Clé publique (côté navigateur). Soit NEXT_PUBLIC_* soit STRIPE_PUBLISHABLE_KEY (les deux acceptés via next.config).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
# Webhook : endpoint /api/webhook → secret whsec_… (Stripe → Developers → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Optionnel : signature des liens « Télécharger le PDF » dans l’email (/api/order-pdf).
# Si absent, STRIPE_WEBHOOK_SECRET puis STRIPE_SECRET_KEY sont utilisés.
# ORDER_DOWNLOAD_SECRET=

RESEND_API_KEY=re_xxxxx
EMAIL_FROM=Qissali <histoires@qissali.fr>
EMAIL_ADMIN=contact@qissali.fr
